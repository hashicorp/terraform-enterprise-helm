# =============================================================================
# TFE Pre-Upgrade Check — Example Environment File
# =============================================================================
# Copy this file and fill in your values, then run:
#   helm install preupgrade-check ./terraform-enterprise-preupgrade-check \
#     --set-file envFile=./tfe.env
# =============================================================================

# === Required ===
TFE_LICENSE=<your-tfe-license>
TFE_HOSTNAME=tfe.example.com
TFE_ENCRYPTION_PASSWORD=<encryption-password>
TFE_OPERATIONAL_MODE=active-active

# === TLS ===
# These paths match the chart's default tls.mountPath.
# If you provide certs via the chart's tls values, these paths are automatic.
TFE_TLS_CERT_FILE=/etc/ssl/private/terraform-enterprise/cert.pem
TFE_TLS_KEY_FILE=/etc/ssl/private/terraform-enterprise/key.pem
# TFE_TLS_CA_BUNDLE_FILE=/etc/ssl/private/terraform-enterprise/ca-bundle.pem
# TFE_TLS_CIPHERS=
# TFE_TLS_VERSION=

# === Database ===
TFE_DATABASE_HOST=db.example.com
TFE_DATABASE_NAME=tfe
TFE_DATABASE_USER=tfe
TFE_DATABASE_PASSWORD=<db-password>
# TFE_DATABASE_PARAMETERS=sslmode=require

# === Object Storage (pick one provider) ===
TFE_OBJECT_STORAGE_TYPE=s3

# S3
TFE_OBJECT_STORAGE_S3_BUCKET=my-tfe-bucket
TFE_OBJECT_STORAGE_S3_REGION=us-west-2
# TFE_OBJECT_STORAGE_S3_ACCESS_KEY_ID=
# TFE_OBJECT_STORAGE_S3_SECRET_ACCESS_KEY=
# TFE_OBJECT_STORAGE_S3_USE_INSTANCE_PROFILE=true
# TFE_OBJECT_STORAGE_S3_ENDPOINT=
# TFE_OBJECT_STORAGE_S3_SERVER_SIDE_ENCRYPTION=
# TFE_OBJECT_STORAGE_S3_SERVER_SIDE_ENCRYPTION_KMS_KEY_ID=

# Azure Blob
# TFE_OBJECT_STORAGE_AZURE_ACCOUNT_NAME=
# TFE_OBJECT_STORAGE_AZURE_ACCOUNT_KEY=
# TFE_OBJECT_STORAGE_AZURE_CONTAINER=
# TFE_OBJECT_STORAGE_AZURE_ENDPOINT=

# GCS
# TFE_OBJECT_STORAGE_GOOGLE_BUCKET=
# TFE_OBJECT_STORAGE_GOOGLE_PROJECT=
# TFE_OBJECT_STORAGE_GOOGLE_CREDENTIALS=

# === Redis ===
TFE_REDIS_URL=redis://redis.example.com:6379
# TFE_REDIS_PASSWORD=
# TFE_REDIS_USE_TLS=false
# TFE_REDIS_USE_AUTH=false
# TFE_REDIS_USER=

# === Vault (optional, for external Vault) ===
# TFE_VAULT_ADDRESS=
# TFE_VAULT_NAMESPACE=
# TFE_VAULT_PATH=
# TFE_VAULT_ROLE_ID=
# TFE_VAULT_SECRET_ID=

# === Capacity (optional) ===
# TFE_CAPACITY_CONCURRENCY=10
# TFE_CAPACITY_CPU=0
# TFE_CAPACITY_MEMORY=2048

# === Misc (optional) ===
# TFE_IACT_SUBNETS=
# TFE_IACT_TIME_LIMIT=
# TFE_RUN_PIPELINE_KUBERNETES_DEBUG_ENABLED=false
